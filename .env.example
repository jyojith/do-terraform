# Copy to .env in the repo root and fill in. Do not commit .env.
# Load with: set -a && source .env && set +a

TF_VAR_do_token=
TF_VAR_argocd_admin_password_hash=

# Optional: Terraform / Terragrunt also accept DO_TOKEN if TF_VAR_do_token is unset
# DO_TOKEN=

# Optional (recommended for CI): shared Terragrunt remote state in S3-compatible storage (e.g. DO Spaces)
# TG_STATE_BUCKET=
# TG_STATE_REGION=us-east-1
# TG_STATE_ENDPOINT=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
