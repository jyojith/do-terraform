# Copy to .env in the repo root and fill in. Do not commit .env.
# Load with: set -a && source .env && set +a

# V2 *personal* API token (dop_v1_...), read+write, same DO account as the domain’s DNS.
# Not: Spaces (S3) access keys, not AWS_ keys for state — those 401 the Domains API.
TF_VAR_do_token=
TF_VAR_argocd_admin_password_hash=

# Optional: Terraform / Terragrunt also accept DO_TOKEN if TF_VAR_do_token is unset
# DO_TOKEN=

# Optional: remote state in S3-compatible storage (e.g. DO Spaces). If bucket, endpoint, and both
# AWS keys are set, Terragrunt uses the S3 backend; otherwise it uses local terraform.tfstate per
# stack (enough for fmt/validate CI without Spaces).
# TG_STATE_BUCKET=bizquery-tf
# TG_STATE_REGION=fra1
# S3 *API* base for the region (not the bucket vhost). Correct:
#   https://fra1.digitaloceanspaces.com
# Same bucket, wrong value for this field (browser / object URL style):
#   https://bizquery-tf.fra1.digitaloceanspaces.com
# TG_STATE_ENDPOINT=https://fra1.digitaloceanspaces.com
# S3 backend signing region (AWS region name; for DO Spaces use us-east-1 unless you know better)
# TG_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
